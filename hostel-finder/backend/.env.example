# Copy this file to .env and fill in your values

# MongoDB connection string
# Local:  mongodb://localhost:27017/hostel-finder
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/hostel-finder
MONGO_URI=mongodb://localhost:27017/hostel-finder

# JWT secret key — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this

# JWT expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
